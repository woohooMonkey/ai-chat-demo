# 服务器配置
PORT=3000
NODE_ENV=development

# Claude API 配置 (用于文本解析和意图分析)
# 从 https://console.anthropic.com/ 获取 API Key
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# MySQL 数据库配置 (用于查询真实数据)
MYSQL_HOST=localhost
MYSQL_USER=root
MYSQL_PASSWORD=123
MYSQL_DATABASE=sales_db

# MCP 服务配置
MCP_SERVER_URL=http://localhost:1123

# 图表存储路径
CHART_STORAGE_PATH=./public/charts
